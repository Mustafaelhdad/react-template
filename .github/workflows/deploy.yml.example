# Deploy workflow template — copy to `deploy.yml` and uncomment one platform.
#
# This file ships with the template as `.yml.example` so GitHub Actions does
# not pick it up automatically. Pick a target (Vercel, Netlify, or GitHub
# Pages), copy this file to `deploy.yml`, uncomment the matching job, and
# wire up the required secrets in Settings → Secrets and variables → Actions.
#
# Required secrets (per platform):
#   Vercel:        VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
#   Netlify:       NETLIFY_AUTH_TOKEN, NETLIFY_SITE_ID
#   GitHub Pages:  none (uses the built-in GITHUB_TOKEN), but you must
#                  enable Pages → Source = GitHub Actions in repo settings.

name: Deploy

on:
  push:
    branches:
      - main
  workflow_dispatch:

concurrency:
  group: deploy-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # --------------------------------------------------------------------
  # Vercel
  # --------------------------------------------------------------------
  # vercel:
  #   name: Deploy to Vercel
  #   runs-on: ubuntu-latest
  #   steps:
  #     - uses: actions/checkout@v5
  #     - uses: actions/setup-node@v5
  #       with:
  #         node-version: 24
  #         cache: npm
  #     - run: npm ci
  #     - run: npm install --global vercel@latest
  #     - run: vercel pull --yes --environment=production --token=${{ secrets.VERCEL_TOKEN }}
  #     - run: vercel build --prod --token=${{ secrets.VERCEL_TOKEN }}
  #     - run: vercel deploy --prebuilt --prod --token=${{ secrets.VERCEL_TOKEN }}

  # --------------------------------------------------------------------
  # Netlify
  # --------------------------------------------------------------------
