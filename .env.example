VITE_APP_NAME="React Template"
VITE_API_BASE_URL=

# Optional i18n overrides. Supported values in this template: "en", "ar".
# Leave unset to use the project defaults in src/shared/i18n/index.ts.
VITE_DEFAULT_LANGUAGE=
VITE_FALLBACK_LANGUAGE=

# Set to "true" in development to boot the app behind the MSW mock worker
# (no backend required). Leave unset in production builds.
VITE_ENABLE_MSW=

# Optional monitoring / analytics slots. The template does not install any SDKs.
VITE_SENTRY_DSN=
VITE_ANALYTICS_KEY=
